# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
API_PREFIX=api
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173

# PostgreSQL / Redis
DATABASE_URL=postgresql://veritab:veritab_dev_only@localhost:5432/veritab?schema=public
REDIS_URL=redis://localhost:6379

# Authentication: generate independent values of at least 32 random bytes.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-random-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=veritab-api
JWT_AUDIENCE=veritab-web
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Server-managed OpenAI-compatible AI gateway. Never expose these values to Vite.
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000

# Base64-encoded 32-byte AES key for outbound webhook credentials.
WEBHOOK_ENCRYPTION_KEY=

# Explicit first-tenant bootstrap. Keep blank until running the one-time job.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
BOOTSTRAP_ORGANIZATION_SLUG=
BOOTSTRAP_ORGANIZATION_NAME=
BOOTSTRAP_PROJECT_KEY=
BOOTSTRAP_PROJECT_NAME=
