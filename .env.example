# Runtime
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
API_PREFIX=api
TRUST_PROXY=false
CORS_ORIGINS=http://localhost:5173

# PostgreSQL / Redis
DATABASE_URL=postgresql://veritab:veritab_dev_only@localhost:5432/veritab?schema=public
REDIS_URL=redis://localhost:6379

# Authentication: generate independent values of at least 32 random bytes.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-random-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=veritab-api
JWT_AUDIENCE=veritab-web
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Initial development administrator; production provisioning must use a secure bootstrap job.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe-Immediately-123!
